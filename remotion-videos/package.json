{
  "name": "supervised-learning-video",
  "version": "1.0.0",
  "description": "监督学习概念讲解动画视频",
  "type": "module",
  "scripts": {
    "start": "remotion preview src/index.ts --port 3030",
    "build": "remotion render src/index.ts SupervisedLearningVideo out/video.mp4 --codec=h264 --audio-codec=aac --pixel-format=yuv420p --gl=angle",
    "build:unsupervised": "remotion render src/index.ts UnsupervisedLearningVideo out/unsupervised-learning.mp4 --codec=h264 --audio-codec=aac --pixel-format=yuv420p --gl=angle",
    "build:cnn": "remotion render src/index.ts CNNVideo out/cnn-video.mp4 --codec=h264 --audio-codec=aac --pixel-format=yuv420p --gl=angle",
    "upgrade": "remotion upgrade",
    "install-deps": "npm install",
    "generate-captions": "node generate-captions.js",
    "render-mermaid": "~/.nvm/versions/node/v20.19.0/bin/node scripts/render-mermaid.mjs"
  },
  "dependencies": {
    "@remotion/animation-utils": "^4.0.132",
    "@remotion/bundler": "^4.0.132",
    "@remotion/captions": "^4.0.132",
    "@remotion/cli": "^4.0.132",
    "@remotion/eslint-config": "^4.0.132",
    "@remotion/google-fonts": "^4.0.434",
    "@remotion/install-whisper-cpp": "^4.0.132",
    "@remotion/light-leaks": "4.0.417",
    "@remotion/media": "^4.0.132",
    "@remotion/player": "^4.0.132",
    "@remotion/renderer": "^4.0.132",
    "@remotion/transitions": "^4.0.132",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.132"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.24",
    "mermaid": "^11.12.3",
    "mermaid-isomorphic": "^3.1.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
